{
  "name": "@sohcah/openapi-generator",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Sam Hindess <mail@sohcah.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sohcah/libraries.git",
    "directory": "packages/openapi-generator"
  },
  "bin": "./dist/cli.mjs",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./cli": {
      "default": "./dist/cli.mjs",
      "types": "./dist/cli.d.mts"
    },
    "./config": {
      "default": "./dist/config.mjs",
      "types": "./dist/config.d.mts"
    },
    "./js": {
      "default": "./dist/js/index.mjs",
      "types": "./dist/js/index.d.mts"
    },
    "./fetch": {
      "default": "./dist/fetch/index.mjs",
      "types": "./dist/fetch/index.d.mts"
    },
    "./generate": {
      "default": "./dist/generate.mjs",
      "types": "./dist/generate.d.mts"
    },
    "./react-query": {
      "default": "./dist/react-query/index.mjs",
      "types": "./dist/react-query/index.d.mts"
    },
    "./react-query/std-runtime": {
      "default": "./dist/react-query/std-runtime.mjs",
      "types": "./dist/react-query/std-runtime.d.mts"
    },
    "./zod": {
      "default": "./dist/zod/index.mjs",
      "types": "./dist/zod/index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "format": "oxfmt",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --run"
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@parcel/watcher": "^2.5.6",
    "@scalar/workspace-store": "^0.40.0",
    "p-debounce": "^5.1.0",
    "regex-escape": "^3.4.11"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/node": "^24.3.0",
    "@types/regex-escape": "^3",
    "openapi-types": "^12.1.3",
    "oxfmt": "^0.50.0",
    "tsdown": "^0.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
