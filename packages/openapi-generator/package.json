{
  "name": "@sohcah/openapi-generator",
  "version": "0.2.3",
  "type": "module",
  "license": "MIT",
  "author": "Sam Hindess <mail@sohcah.dev>",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": "./dist/cli.mjs",
  "exports": {
    ".": {
      "default": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./config": {
      "default": "./dist/config.mjs",
      "types": "./dist/config.d.mts"
    },
    "./generators": {
      "default": "./dist/generators/index.mjs",
      "types": "./dist/generators/index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "cli": "./dist/cli.mjs",
    "sample": "yarn build && yarn cli generate -c ./sample/openapi.config.ts && SCHEMA_FORMAT=effect yarn cli generate -c ./sample/openapi.config.ts && SCHEMA_FORMAT=zod-mini yarn cli generate -c ./sample/openapi.config.ts"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.19",
    "@types/babel__generator": "^7.27.0",
    "@types/node": "^24.3.0",
    "@types/regex-escape": "^3",
    "openapi-types": "^12.1.3",
    "tsdown": "^0.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@effect/cli": "^0.73.0",
    "@effect/cluster": "^0.56.1",
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "^0.94.1",
    "@effect/platform-node": "^0.104.0",
    "@effect/printer-ansi": "^0.47.0",
    "@effect/rpc": "^0.73.0",
    "@effect/sql": "^0.49.0",
    "@effect/typeclass": "^0.38.0",
    "@scalar/openapi-parser": "^0.24.2",
    "effect": "^3.19.14",
    "regex-escape": "^3.4.11",
    "zod": "^4.3.5"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
